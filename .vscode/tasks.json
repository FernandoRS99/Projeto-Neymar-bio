{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Git: Add + Commit + Push",
      "type": "shell",
      "command": "git add . && git commit -m \"${input:commitMessage}\" && git push",
      "problemMatcher": [],
      "group": "build"
    }
  ],
  "inputs": [
    {
      "id": "commitMessage",
      "type": "promptString",
      "description": "Digite a mensagem do commit"
    }
  ]
}